# Copy to .env (or export in your shell) before running the smoke test.
#
# The MCP server reads these from its launch environment — the values come
# from the `env` block in your .mcp.json when the server runs under Claude
# Code / Cursor, or from the warehouse resource binding when deployed as a
# Databricks App.

# Databricks CLI profile from ~/.databrickscfg. The SDK uses this to resolve
# host + auth method. Required. The default profile created by
# `databricks auth login` is named DEFAULT.
DATABRICKS_CONFIG_PROFILE=DEFAULT

# SQL warehouse ID to pin all queries to. Required for warehouse pinning.
# Look up via: `databricks warehouses list --profile DEFAULT`
# The `id` field (a 16-character hex string) is what you want.
DATABRICKS_WAREHOUSE_ID=replace-with-your-warehouse-id
