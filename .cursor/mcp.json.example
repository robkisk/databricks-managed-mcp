{
  "_comment": "Template wiring Databricks MCP servers into MCP clients (Claude Code, Cursor, etc.). Copy this file to .mcp.json (or merge into an existing one), replace every <placeholder> with your real values, then restart your client so the servers load. Two proxy implementations are shown below — pick whichever fits your distribution story; both bridge stdio<->HTTPS with Databricks OAuth and target the same managed Databricks MCP endpoints. Path patterns:  Genie -> /api/2.0/mcp/genie/<space-id>  ;  UC Functions -> /api/2.0/mcp/functions/<catalog>/<schema>  ;  Vector Search -> /api/2.0/mcp/vector-search/<catalog>/<schema>  ;  DBSQL -> /api/2.0/mcp/sql .  Copy whichever entries you need and delete the rest.",

  "mcpServers": {
    "_CUSTOM_PROXY_GENIE": {
      "_description": "Genie space via the hand-rolled proxy (mcp_proxy.py in this repo). The proxy reads --profile from ~/.databrickscfg to resolve the workspace host, then appends --path. Replace <genie-space-id> with the ID from the Genie space URL.",
      "command": "uv",
      "args": [
        "run",
        "./mcp_proxy.py",
        "--path",
        "/api/2.0/mcp/genie/<genie-space-id>",
        "--profile",
        "<your-profile>"
      ]
    },

    "_CUSTOM_PROXY_UC_FUNCTIONS": {
      "_description": "UC Functions via the hand-rolled proxy. Exposes every UC function in <catalog>.<schema> as a tool.",
      "command": "uv",
      "args": [
        "run",
        "./mcp_proxy.py",
        "--path",
        "/api/2.0/mcp/functions/<catalog>/<schema>",
        "--profile",
        "<your-profile>"
      ]
    },

    "_CUSTOM_PROXY_VECTOR_SEARCH": {
      "_description": "Vector Search via the hand-rolled proxy. Exposes every Vector Search index in <catalog>.<schema> as a retrieval tool.",
      "command": "uv",
      "args": [
        "run",
        "./mcp_proxy.py",
        "--path",
        "/api/2.0/mcp/vector-search/<catalog>/<schema>",
        "--profile",
        "<your-profile>"
      ]
    },

    "_CUSTOM_PROXY_DBSQL": {
      "_description": "DBSQL via the hand-rolled proxy. Lets the client execute SQL against the workspace's default warehouse.",
      "command": "uv",
      "args": [
        "run",
        "./mcp_proxy.py",
        "--path",
        "/api/2.0/mcp/sql",
        "--profile",
        "<your-profile>"
      ]
    },

    "_UVX_PROXY_GENIE": {
      "_description": "Genie space via the PyPI uc-mcp-proxy package. uvx fetches it on first run — no install step. Unlike the hand-rolled proxy, --url takes the FULL HTTPS URL (no profile-based host resolution), so replace <workspace-host> with your workspace domain (e.g. fevm-yourorg.cloud.databricks.com).",
      "type": "stdio",
      "command": "uvx",
      "args": [
        "uc-mcp-proxy",
        "--url",
        "https://<workspace-host>/api/2.0/mcp/genie/<genie-space-id>",
        "--auth-type",
        "databricks-cli",
        "--profile",
        "<your-profile>"
      ]
    },

    "_UVX_PROXY_UC_FUNCTIONS": {
      "_description": "UC Functions via the PyPI uc-mcp-proxy package.",
      "type": "stdio",
      "command": "uvx",
      "args": [
        "uc-mcp-proxy",
        "--url",
        "https://<workspace-host>/api/2.0/mcp/functions/<catalog>/<schema>",
        "--auth-type",
        "databricks-cli",
        "--profile",
        "<your-profile>"
      ]
    },

    "_UVX_PROXY_VECTOR_SEARCH": {
      "_description": "Vector Search via the PyPI uc-mcp-proxy package.",
      "type": "stdio",
      "command": "uvx",
      "args": [
        "uc-mcp-proxy",
        "--url",
        "https://<workspace-host>/api/2.0/mcp/vector-search/<catalog>/<schema>",
        "--auth-type",
        "databricks-cli",
        "--profile",
        "<your-profile>"
      ]
    },

    "_UVX_PROXY_DBSQL": {
      "_description": "DBSQL via the PyPI uc-mcp-proxy package.",
      "type": "stdio",
      "command": "uvx",
      "args": [
        "uc-mcp-proxy",
        "--url",
        "https://<workspace-host>/api/2.0/mcp/sql",
        "--auth-type",
        "databricks-cli",
        "--profile",
        "<your-profile>"
      ]
    }
  }
}
